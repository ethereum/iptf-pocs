pragma solidity ^0.8.21;

import {Script, console} from "forge-std/Script.sol";
import {Config} from "forge-std/Config.sol";
import {HonkVerifier as ClaimHonkVerifier} from "../src/verifiers/ClaimVerifier.sol";
import {HonkVerifier as WithdrawHonkVerifier} from "../src/verifiers/WithdrawVerifier.sol";

/// @title DeployVerifiers
/// @notice Deploys the real Honk verifiers generated by
///         `scripts/generate-verifiers.sh`. Run before `Deploy.s.sol` with
///         `use_mock_verifier = false` to wire real verifiers into the
///         CompositeVerifier.
contract DeployVerifiers is Script, Config {
    function run() public {
        _loadConfig("./deployments.toml", true);

        vm.startBroadcast();

        address claimVerifier = address(new ClaimHonkVerifier());
        address withdrawVerifier = address(new WithdrawHonkVerifier());

        vm.stopBroadcast();

        config.set("claim_verifier_address", claimVerifier);
        config.set("withdraw_verifier_address", withdrawVerifier);

        console.log("");
        console.log("=== Verifier Deployment Summary ===");
        console.log("ClaimVerifier:", claimVerifier);
        console.log("WithdrawVerifier:", withdrawVerifier);
    }
}
