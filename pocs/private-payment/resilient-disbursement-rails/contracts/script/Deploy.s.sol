pragma solidity ^0.8.21;

import {Script, console} from "forge-std/Script.sol";
import {Config} from "forge-std/Config.sol";
import {Multisig} from "../src/Multisig.sol";
import {Registry} from "../src/Registry.sol";
import {ShieldedPool} from "../src/ShieldedPool.sol";
import {ClaimContract} from "../src/ClaimContract.sol";
import {RoundFactory} from "../src/RoundFactory.sol";
import {CompositeVerifier} from "../src/CompositeVerifier.sol";
import {MockERC20} from "../src/mocks/MockERC20.sol";
import {MockClaimVerifier} from "../src/mocks/MockClaimVerifier.sol";
import {MockWithdrawVerifier} from "../src/mocks/MockWithdrawVerifier.sol";
import {HonkVerifier as ClaimHonkVerifier} from "../src/verifiers/ClaimVerifier.sol";
import {HonkVerifier as WithdrawHonkVerifier} from "../src/verifiers/WithdrawVerifier.sol";

/// @title Deploy
/// @notice Deploy script for resilient-disbursement-rails. Mocks the
///         circuit verifiers when `use_mock_verifier = true`; otherwise uses
///         the verifiers generated by `scripts/generate-verifiers.sh`.
contract Deploy is Script, Config {
    function run() public {
        _loadConfig("./deployments.toml", true);

        bool useMockVerifier = config.get("use_mock_verifier").toBool();

        address governance = config.get("governance").toAddress();
        address operatorKey = config.get("operator_key").toAddress();
        address residualDest = config.get("funder_residual_destination").toAddress();

        vm.startBroadcast();

        // 1. MockERC20 token (single-asset pool target).
        MockERC20 mockToken = new MockERC20("Mock USDC", "mUSDC", 6);
        console.log("MockERC20:", address(mockToken));

        // 2. Funder Multisig.
        address[7] memory funderOwners = _funderOwnersForChain();
        Multisig funderMultisig = new Multisig(funderOwners);
        console.log("Multisig (funder):", address(funderMultisig));

        // 3. Verifiers.
        address claimVerifierAddr;
        address withdrawVerifierAddr;
        if (useMockVerifier) {
            claimVerifierAddr = address(new MockClaimVerifier());
            withdrawVerifierAddr = address(new MockWithdrawVerifier());
            console.log("MockClaimVerifier:", claimVerifierAddr);
            console.log("MockWithdrawVerifier:", withdrawVerifierAddr);
        } else {
            claimVerifierAddr = address(new ClaimHonkVerifier());
            withdrawVerifierAddr = address(new WithdrawHonkVerifier());
            console.log("ClaimVerifier:", claimVerifierAddr);
            console.log("WithdrawVerifier:", withdrawVerifierAddr);
        }

        // 4. CompositeVerifier.
        CompositeVerifier composite = new CompositeVerifier(claimVerifierAddr, withdrawVerifierAddr);
        console.log("CompositeVerifier:", address(composite));

        // 5. Registry.
        Registry registry = new Registry(operatorKey, governance);
        console.log("Registry:", address(registry));

        // 6. ClaimContract (configured below).
        ClaimContract claimContract = new ClaimContract(governance);
        console.log("ClaimContract:", address(claimContract));

        // 7. ShieldedPool.
        ShieldedPool pool = new ShieldedPool(address(mockToken), address(composite), governance);
        console.log("ShieldedPool:", address(pool));

        // 8. RoundFactory (knows all of the above).
        RoundFactory factory = new RoundFactory(
            address(registry), address(pool), address(claimContract), address(mockToken), address(funderMultisig)
        );
        console.log("RoundFactory:", address(factory));

        vm.stopBroadcast();

        // Wiring requires the governance signer; do it under a separate
        // broadcast scope so anvil signs as governance for these calls if
        // PRIVATE_KEY corresponds to governance. For local testing the
        // deployer is governance.
        vm.startBroadcast();
        pool.initAuthorizedFactory(address(factory));
        claimContract.setFactory(address(factory));
        claimContract.setPool(address(pool));
        claimContract.setVerifier(address(composite));
        claimContract.setToken(address(mockToken));
        claimContract.setFunderMultisig(address(funderMultisig));
        claimContract.setFunderResidualDestination(residualDest);
        vm.stopBroadcast();

        // Persist addresses.
        config.set("mock_token_address", address(mockToken));
        config.set("funder_multisig_address", address(funderMultisig));
        config.set("composite_verifier_address", address(composite));
        config.set("claim_verifier_address", claimVerifierAddr);
        config.set("withdraw_verifier_address", withdrawVerifierAddr);
        config.set("registry_address", address(registry));
        config.set("claim_contract_address", address(claimContract));
        config.set("shielded_pool_address", address(pool));
        config.set("round_factory_address", address(factory));

        console.log("");
        console.log("=== Deployment Summary ===");
        console.log("Chain ID:", block.chainid);
        console.log("MockERC20:", address(mockToken));
        console.log("Multisig:", address(funderMultisig));
        console.log("Registry:", address(registry));
        console.log("ShieldedPool:", address(pool));
        console.log("ClaimContract:", address(claimContract));
        console.log("RoundFactory:", address(factory));
        console.log("CompositeVerifier:", address(composite));
    }

    /// @dev Default funder-multisig owners for local anvil. Real deployments
    ///      override per-environment.
    function _funderOwnersForChain() internal pure returns (address[7] memory owners) {
        // Anvil default test addresses.
        owners[0] = 0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266;
        owners[1] = 0x70997970C51812dc3A010C7d01b50e0d17dc79C8;
        owners[2] = 0x3C44CdDdB6a900fa2b585dd299e03d12FA4293BC;
        owners[3] = 0x90F79bf6EB2c4f870365E785982E1f101E93b906;
        owners[4] = 0x15d34AAf54267DB7D7c367839AAf71A00a2C6A65;
        owners[5] = 0x9965507D1a55bcC2695C58ba16FB37d819B0A4dc;
        owners[6] = 0x976EA74026E726554dB657fA54763abd0C3a0aa9;
    }
}
